{
  "name": "test-ai/symfony-api",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "ext-pdo": "*",
    "ext-pgsql": "*",
    "symfony/console": "7.3.*",
    "symfony/dotenv": "7.3.*",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "7.3.*",
    "symfony/password-hasher": "7.3.*",
    "symfony/runtime": "7.3.*",
    "symfony/yaml": "7.3.*",
    "doctrine/dbal": "^4.3",
    "symfony/security-core": "7.3.*"
  },
  "require-dev": {
    "symfony/maker-bundle": "^1.62"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "7.3.*"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    }
  }
}
